        <mxCell id="fetch" value="RAW 로그 조회&#10;&#10;- mbeat.er_data_raw 사용&#10;- code_occur_time 범위 조건&#10;- TARGET_CODES exact match 필터&#10;- code_occur_time, eq_name, er_date, er_index 정렬&#10;- SQLAlchemy execute + fetchmany&#10;- chunk 단위 streaming fetch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;align=left;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="450" y="240" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="parser" value="ERDoseProcessor + DoseErrorParser&#10;&#10;- chunk 내부 row별 RawErLog 생성&#10;- code_occur_time은 Python datetime으로 정규화&#10;- belong/type/title/contents는 원천 그대로 보존&#10;- DW/LO/KE code 기준 파싱&#10;- exposure_handle, action_handle, wafer_id, wafer_seq, de_err, n_slit 추출&#10;- wafer state는 eq_name 기준 chunk 간 유지" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;align=left;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="810" y="240" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="status" value="chunk 진행 로그&#10;&#10;- start_time / end_time / chunk_size 출력&#10;- chunk별 fetched / parsed / inserted 출력&#10;- partition_date별 row 수 출력&#10;- 최종 fetched / inserted summary 출력" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;align=left;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="1170" y="240" width="300" height="170" as="geometry" />
