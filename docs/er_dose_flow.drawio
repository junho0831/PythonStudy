          <mxGeometry x="740" y="220" width="280" height="190" as="geometry"/>
        </mxCell>
        <mxCell id="parsed" value="mbeat.er_dose_error_parsed&#xa;&#xa;핵심 이력 컬럼&#xa;- id&#xa;- code_occur_time&#xa;- eq_name / code&#xa;- exposure_handle&#xa;- parsing_status&#xa;- raw_contents&#xa;- created_at" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;align=left;spacing=14;" vertex="1" parent="1">
