        <mxCell id="title" value="ER Dose Error 이력 적재 구조" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;" vertex="1" parent="1">
          <mxGeometry x="60" y="40" width="520" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="note" value="ER_DATA_RAW에는 er_date, er_index, raw_id가 없다. 파싱 결과는 기존 row를 수정/삭제하지 않고 이력으로 append 적재한다." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="95" width="760" height="60" as="geometry"/>
